--- a/target/i386/tcg/emit.c.inc
+++ b/target/i386/tcg/emit.c.inc
@@ -4648,6 +4648,61 @@
 #define gen_WRMSR gen_unreachable
 #endif
 
+/* pinball2000: Cyrix MediaGX/5530 opcode 0F 3C compatibility shim.
+ *
+ * The Cyrix MediaGX databook documents 0F 3C as CPU_WRITE: EBX holds an
+ * internal-CPU-register address, EAX holds the data, and the result is
+ * written into a CPU-internal configuration register (BLT buffer base /
+ * pointer, GP-DMA descriptors, etc). True CPU_WRITE semantics are NOT
+ * implemented here.
+ *
+ * Instead this generator first invokes the gated log helper (which
+ * raises #UD if the pinball2000 machine isn't active, preserving stock
+ * i386 behavior) and then reproduces the observable side effect of the
+ * Unicorn / legacy QEMU low-RAM IDT[6] stub that Pinball 2000's XINU
+ * bring-up code relies on:
+ *
+ *     [DS:EDX]   := EAX        ; 32-bit
+ *     [DS:EDX+4] := EBX        ; 32-bit
+ *     EDX        += 8
+ *
+ * (Reference: unicorn.old/src/cpu.c:587-628 and the deleted
+ * qemu/p2k-cyrix-0f3c.c host-side stub.) The XINU users of 0F 3C
+ * happen to only care about this pointer-walk pattern, not about the
+ * real CPU_WRITE register address space, so emulating the shim is
+ * sufficient for the matrix. Long-term direction is real CPU_WRITE /
+ * CPU_READ (0F 3D) handling, gated to the MediaGX/pinball2000 machine.
+ */
+static void gen_CYRIX_0F3C_shim(DisasContext *s, X86DecodedInsn *decode)
+{
+    /* Log first; helper raises #UD if the gate is off (stock i386). */
+    gen_helper_p2k_mediagx_log_0f3x_shim(tcg_env,
+                                         tcg_constant_i32(0x3C),
+                                         eip_cur_tl(s));
+    /* Observable side-effect mirror of the old Unicorn / IDT[6] stub. */
+    gen_lea_v_seg(s, cpu_regs[R_EDX], R_DS, s->override);
+    tcg_gen_qemu_st_tl(cpu_regs[R_EAX], s->A0, s->mem_index, MO_LEUL);
+    tcg_gen_addi_tl(s->A0, s->A0, 4);
+    tcg_gen_qemu_st_tl(cpu_regs[R_EBX], s->A0, s->mem_index, MO_LEUL);
+    tcg_gen_addi_tl(cpu_regs[R_EDX], cpu_regs[R_EDX], 8);
+}
+
+/* pinball2000: observation entry for the unimplemented MediaGX 0F 3x
+ * slots (0F 36/37/39/3B/3D/3F). Always raises #UD; logs the regs +
+ * EIP rate-limited when the pinball2000 gate is enabled, so we can
+ * see if the guest ever issues a documented MediaGX opcode we haven't
+ * implemented yet (notably 0F 3B BB1_RESET and 0F 3D CPU_READ). */
+static void gen_CYRIX_0F3x_log_ud(DisasContext *s, X86DecodedInsn *decode)
+{
+    /* decode->b holds the second byte of the 0F-prefix opcode (see
+     * do_decode_0F in decode-new.c.inc). */
+    uint32_t op2 = (uint32_t)(decode->b & 0xFFu);
+    gen_helper_p2k_mediagx_log_0f3x_ud(tcg_env,
+                                       tcg_constant_i32(op2),
+                                       eip_cur_tl(s));
+    s->base.is_jmp = DISAS_NORETURN;
+}
+
 static void gen_WRxxBASE(DisasContext *s, X86DecodedInsn *decode)
 {
     TCGv base = cpu_seg_base[s->modrm & 8 ? R_GS : R_FS];
