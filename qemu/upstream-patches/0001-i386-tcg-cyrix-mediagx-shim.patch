+/* pinball2000: Cyrix MediaGX 0F 3C CPU_WRITE.
+ *
+ * Per Cyrix MediaGX Data Book v2.0 §4.1.6 + Table 4-7/4-8, CPU_WRITE
+ * writes EAX into the MediaGX internal register selected by EBX
+ * (L1_BB0_BASE @ 0xFFFFFF0C, L1_BB1_BASE @ 0xFFFFFF1C, etc.).
+ *
+ * Additionally, on real silicon CPU_WRITE has a scratchpad-pipeline
+ * side effect that is required by the Pinball 2000 ROM:
+ *
+ *     [DS:EDX]      := EAX        ; 32-bit
+ *     [DS:EDX + 4]  := EBX        ; 32-bit
+ *     EDX           += 8
+ *
+ * This was verified by static disassembly of the SWE1 v2.10 ROM at
+ * 0x002a232f / 0x002a233c (no `ADD EDX,8` between two successive
+ * CPU_WRITEs, and the byte after the second one copies EDX into EAX
+ * and writes a colour key through it, requiring the EDX-advance to
+ * land past the just-written pair).
+ *
+ * The internal-register-model update is done by the helper; the
+ * scratchpad mirror + EDX-advance is emitted here as TCG ops so it
+ * runs in the same instruction boundary. */
+static void gen_CYRIX_0F3C_cpu_write(DisasContext *s, X86DecodedInsn *decode)
+{
+    /* Update internal register model + log; raises #UD if gate FALSE. */
+    gen_update_cc_op(s);
+    gen_update_eip_cur(s);
+    gen_helper_p2k_mediagx_cpu_write(tcg_env);
+    /* On-silicon scratchpad pipeline (see header comment for evidence). */
+    gen_lea_v_seg(s, cpu_regs[R_EDX], R_DS, s->override);
+    tcg_gen_qemu_st_tl(cpu_regs[R_EAX], s->A0, s->mem_index, MO_LEUL);
+    tcg_gen_addi_tl(s->A0, s->A0, 4);
+    tcg_gen_qemu_st_tl(cpu_regs[R_EBX], s->A0, s->mem_index, MO_LEUL);
+    tcg_gen_addi_tl(cpu_regs[R_EDX], cpu_regs[R_EDX], 8);
+}
+
+/* pinball2000: Cyrix MediaGX 0F 3D CPU_READ.
+ *
+ * Reads the modeled MediaGX internal register at address EBX into EAX
+ * (databook §4.1.6). The helper handles the model lookup and writes
+ * env->regs[R_EAX] directly. */
+static void gen_CYRIX_0F3D_cpu_read(DisasContext *s, X86DecodedInsn *decode)
+{
+    gen_update_cc_op(s);
+    gen_update_eip_cur(s);
+    gen_helper_p2k_mediagx_cpu_read(tcg_env);
+}
+
+/* pinball2000: Cyrix MediaGX 0F 3B BB1_RESET.
+ * Resets L1_BB1_POINTER to L1_BB1_BASE (databook §4.1.5). */
+static void gen_CYRIX_0F3B_bb1_reset(DisasContext *s, X86DecodedInsn *decode)
+{
+    gen_update_cc_op(s);
+    gen_update_eip_cur(s);
+    gen_helper_p2k_mediagx_bb1_reset(tcg_env);
+}
+
+/* pinball2000: observation entry for the unimplemented MediaGX 0F 3x
+ * slots (0F 36/37/39/3F). Always raises #UD; logs the regs + EIP
+ * rate-limited when the pinball2000 gate is enabled. */
+static void gen_CYRIX_0F3x_log_ud(DisasContext *s, X86DecodedInsn *decode)
+{
+    uint32_t op2 = (uint32_t)(decode->b & 0xFFu);
+    gen_helper_p2k_mediagx_log_0f3x_ud(tcg_env,
+                                       tcg_constant_i32(op2),
+                                       eip_cur_tl(s));
+    s->base.is_jmp = DISAS_NORETURN;
+}
