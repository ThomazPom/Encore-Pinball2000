@@ -25,6 +25,132 @@
 #include "exec/cputlb.h"
 #include "helper-tcg.h"
 
+/* ====================================================================
+ * Pinball 2000 / Cyrix MediaGX TCG opcode-extension helpers.
+ *
+ * Backed by qemu/p2k-mediagx-gate.c (linked into hw/i386/). Gate is
+ * FALSE by default; pinball2000 machine init flips it TRUE. When FALSE
+ * these helpers behave as plain #UD so a stock qemu-system-i386 run
+ * is not affected by the decode-table additions in decode-new.c.inc.
+ *
+ * For the on-silicon CPU_WRITE pipeline (scratchpad mirror + EDX += 8)
+ * the storage half is emitted by the TCG generator in emit.c.inc; the
+ * helper only handles the internal-register-model side and logging.
+ * ==================================================================== */
+extern bool     p2k_mediagx_extensions_enabled;
+extern unsigned p2k_mediagx_note_opcode(uint8_t op2);
+extern void     p2k_mediagx_internal_reg_write(uint32_t ebx_addr,
+                                               uint32_t value);
+extern uint32_t p2k_mediagx_internal_reg_read(uint32_t ebx_addr);
+extern void     p2k_mediagx_bb1_reset_internal(void);
+extern uint8_t  p2k_cyrix_ccr_get(uint8_t index);
+
+/* Databook §4.1.5: GCR[B8h] bits[3:2] = SCRATCHPAD_SIZE. Zero means
+ * the Display-Driver Instructions are disabled and must #UD. The
+ * pinball2000 CCR module exposes 0x0D so this check normally passes;
+ * if anything ever clears those bits the helper will refuse to act. */
+static inline bool p2k_mediagx_dd_enabled(void)
+{
+    return p2k_mediagx_extensions_enabled
+        && ((p2k_cyrix_ccr_get(0xb8u) & 0x0Cu) != 0u);
+}
+
+static void p2k_mediagx_log(CPUX86State *env, uint32_t op2,
+                            target_ulong eip, const char *kind,
+                            unsigned hit)
+{
+    qemu_log_mask(LOG_GUEST_ERROR,
+        "p2k-mediagx: %s 0F %02X #%u "
+        "EIP=" TARGET_FMT_lx " "
+        "EAX=%08x EBX=%08x ECX=%08x EDX=%08x "
+        "ESI=%08x EDI=%08x EBP=%08x ESP=%08x "
+        "EFLAGS=%08x CS=%04x DS=%04x\n",
+        kind, op2 & 0xFFu, hit, eip,
+        (uint32_t)env->regs[R_EAX], (uint32_t)env->regs[R_EBX],
+        (uint32_t)env->regs[R_ECX], (uint32_t)env->regs[R_EDX],
+        (uint32_t)env->regs[R_ESI], (uint32_t)env->regs[R_EDI],
+        (uint32_t)env->regs[R_EBP], (uint32_t)env->regs[R_ESP],
+        (uint32_t)env->eflags,
+        env->segs[R_CS].selector, env->segs[R_DS].selector);
+}
+
+/* 0F 3C CPU_WRITE.
+ *
+ * Updates the modeled MediaGX internal register at address EBX with
+ * value EAX (databook §4.1.6, Table 4-7/4-8). The TCG generator in
+ * emit.c.inc additionally emits an EDX scratchpad pipeline
+ * ([DS:EDX]:=EAX; [DS:EDX+4]:=EBX; EDX+=8) which is NOT documented
+ * in §4.1.5/4.1.6 but is directly observed in the Pinball 2000 ROM
+ * (two back-to-back 0F3Cs separated only by MOV reg,[abs32], and
+ * the post-instruction EDX is reused as a write pointer). Treat it
+ * as observed silicon/ROM contract rather than table semantics. */
+void helper_p2k_mediagx_cpu_write(CPUX86State *env)
+{
+    if (!p2k_mediagx_dd_enabled()) {
+        raise_exception_err_ra(env, EXCP06_ILLOP, 0, GETPC());
+    }
+    uint32_t ebx = (uint32_t)env->regs[R_EBX];
+    uint32_t eax = (uint32_t)env->regs[R_EAX];
+    p2k_mediagx_internal_reg_write(ebx, eax);
+    unsigned hit = p2k_mediagx_note_opcode(0x3C);
+    if (hit <= 16 || (hit & 0x3FFu) == 0) {
+        p2k_mediagx_log(env, 0x3C, env->eip, "CPU_WRITE", hit);
+    }
+}
+
+/* 0F 3D CPU_READ.
+ *
+ * Reads the modeled MediaGX internal register at address EBX into EAX
+ * (databook §4.1.6, Table 4-7/4-8). No scratchpad / EDX side effect
+ * has been observed for CPU_READ on silicon; if one is later
+ * discovered it should be added symmetrically with CPU_WRITE. */
+void helper_p2k_mediagx_cpu_read(CPUX86State *env)
+{
+    if (!p2k_mediagx_dd_enabled()) {
+        raise_exception_err_ra(env, EXCP06_ILLOP, 0, GETPC());
+    }
+    uint32_t ebx = (uint32_t)env->regs[R_EBX];
+    uint32_t value = p2k_mediagx_internal_reg_read(ebx);
+    env->regs[R_EAX] = value;
+    unsigned hit = p2k_mediagx_note_opcode(0x3D);
+    if (hit <= 16 || (hit & 0x3FFu) == 0) {
+        p2k_mediagx_log(env, 0x3D, env->eip, "CPU_READ", hit);
+        qemu_log_mask(LOG_GUEST_ERROR,
+            "p2k-mediagx:   CPU_READ EBX=%08x -> EAX=%08x\n", ebx, value);
+    }
+}
+
+/* 0F 3B BB1_RESET — reset L1_BB1_POINTER to L1_BB1_BASE
+ * (databook §4.1.5, Table 4-6). */
+void helper_p2k_mediagx_bb1_reset(CPUX86State *env)
+{
+    if (!p2k_mediagx_dd_enabled()) {
+        raise_exception_err_ra(env, EXCP06_ILLOP, 0, GETPC());
+    }
+    p2k_mediagx_bb1_reset_internal();
+    unsigned hit = p2k_mediagx_note_opcode(0x3B);
+    if (hit <= 16 || (hit & 0x3FFu) == 0) {
+        p2k_mediagx_log(env, 0x3B, env->eip, "BB1_RESET", hit);
+    }
+}
+
+/* Used by the 0F 36/37/39/3F observation decoder entries. We don't
+ * have a real implementation; we just want to know *if* the guest
+ * hits them. Always raises #UD (matching stock i386 behavior), but
+ * logs first occurrences when the gate is on. */
+G_NORETURN void helper_p2k_mediagx_log_0f3x_ud(CPUX86State *env,
+                                               uint32_t op2,
+                                               target_ulong eip)
+{
+    if (p2k_mediagx_extensions_enabled) {
+        unsigned hit = p2k_mediagx_note_opcode((uint8_t)op2);
+        if (hit <= 16 || (hit & 0x3FFu) == 0) {
+            p2k_mediagx_log(env, op2, eip, "log+UD", hit);
+        }
+    }
+    raise_exception_err_ra(env, EXCP06_ILLOP, 0, GETPC());
+}
+
