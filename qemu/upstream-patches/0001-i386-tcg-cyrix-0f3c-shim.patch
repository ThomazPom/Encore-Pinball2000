+    /* pinball2000: Cyrix MediaGX 0F 3C compatibility shim (NOT true
+     * CPU_WRITE). Stores EAX into [DS:EDX], EBX into [DS:EDX+4], then
+     * EDX += 8. Reproduces the observable side effect of the legacy
+     * Unicorn IDT[6] stub. Generator in emit.c.inc. Real MediaGX
+     * CPU_WRITE/CPU_READ semantics are not implemented. */
+    [0x3C] = X86_OP_ENTRY0(CYRIX_0F3C_shim),
+
